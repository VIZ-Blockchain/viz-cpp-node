      { "id": 51, "name": "paid_subscribe_operation", "isVirtual": false, "status": "active" },
      { "id": 52, "name": "paid_subscription_action_operation", "isVirtual": true, "status": "active" },
      { "id": 53, "name": "cancel_paid_subscription_operation", "isVirtual": true, "status": "active" },
      { "id": 54, "name": "set_account_price_operation", "isVirtual": false, "status": "active" },
      { "id": 55, "name": "set_subaccount_price_operation", "isVirtual": false, "status": "active" },
      { "id": 56, "name": "buy_account_operation", "isVirtual": false, "status": "active" },
